# 1. Gestione Fine Riga (End of Line)
# ----------------------------------
# Forza tutti i file di testo a usare LF al momento del commit.
# In fase di checkout, Git userà il formato nativo del sistema operativo se non specificato diversamente.
* text=auto eol=lf
# 2. File di Codice e Configurazione (Sempre LF)
# ---------------------------------------------
*.cs diff=csharp text eol=lf
*.cginc text eol=lf
*.shader text eol=lf
*.mat text eol=lf
*.anim text eol=lf
*.asset text eol=lf
*.unity text eol=lf
*.prefab text eol=lf
*.physicsMaterial2D text eol=lf
*.physicsMaterial text eol=lf
*.asset text eol=lf
*.meta text eol=lf
*.controller text eol=lf
# 3. File Binari (Devono rimanere inalterati)
# ------------------------------------------
# L'attributo -text indica a Git di non toccare i fine riga.
*.jpg filter=lfs diff=lfs merge=lfs -text
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg binary
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.gif binary
*.psd filter=lfs diff=lfs merge=lfs -text
*.ai binary
*.tga filter=lfs diff=lfs merge=lfs -text
*.tiff binary
*.fbx filter=lfs diff=lfs merge=lfs -text
*.obj filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
*.mp3 filter=lfs diff=lfs merge=lfs -text
*.ogg binary
*.dll filter=lfs diff=lfs merge=lfs -text
*.exe binary
*.pdf binary
*.zip binary
*.unitypackage binary
*.max filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text
*.pdb filter=lfs diff=lfs merge=lfs -text
*.skp filter=lfs diff=lfs merge=lfs -text
